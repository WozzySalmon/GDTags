# Normalize EOL for all files that Git considers text files.
* text=auto eol=lf

# Keep local tooling/dependencies out of distributable git archives.
addons/godot_ai/** export-ignore
godot-cpp/** export-ignore
.godot/** export-ignore
bin/** export-ignore
addons/gameplay_tags/bin/** export-ignore
*.obj export-ignore
*.pdb export-ignore
*.lib export-ignore
*.exp export-ignore
